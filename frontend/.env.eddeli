# Perfiles EdDeli (el comando fija suscripciones; no hace falta tocar esto):
#   npm run dev:eddeli  → libre (sin permisos)
#   npm run eddeli      → con entitlement (como prod)
#   npm run build:eddeli → producción (suscripciones ON + API production)
VITE_BASE_PATH=/eddeli/
VITE_API_PREFIX=eddeliapi
VITE_API_PORT=3001
VITE_API_HOST=127.0.0.1
VITE_API_ORIGIN=https://aplicaciones.marianosamaniego.edu.ec
VITE_MEDIA_PREFIX=sistema
VITE_DEV_PORT=5173
VITE_APP_NAME=EdDeli
VITE_APP_ID=eddeli
