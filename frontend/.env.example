# Frontend compartido Raptor — una app nueva = copiar este archivo a .env.<mode>
#
#   npm run eddeli              → .env.eddeli
#   npm run store               → .env.store
#   npm run build:app -- scheduly → .env.scheduly (sin tocar copy-build ni package.json)
#
# Deploy: por defecto copia a ../../<mode>/ (hermana de raptor/, ej. projects/eddeli).
# Override: VITE_DEPLOY_DIR=../../scheduly  (relativa a frontend/ o ruta absoluta)
# Sin copia:  VITE_SKIP_DEPLOY=true  (modo raptor lo hace automático)

VITE_BASE_PATH=/eddeli/
VITE_API_PREFIX=eddeliapi
VITE_API_PORT=3001
VITE_API_HOST=127.0.0.1
VITE_API_ORIGIN=https://aplicaciones.marianosamaniego.edu.ec
# VITE_API_MODE: omitir en apps con backend → dev=local, build=production
# Modo invitado (raptor): VITE_SHELL_ONLY=true y VITE_API_MODE=none
VITE_MEDIA_PREFIX=sistema
VITE_DEV_PORT=5173
VITE_APP_NAME=EdDeli
VITE_APP_ID=eddeli
# VITE_SUBSCRIPTIONS_ENABLED=true
# VITE_DEPLOY_DIR=../../eddeli
# VITE_SKIP_DEPLOY=false
