{
  "name": "frontend-raptor",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:eddeli",
    "dev:eddeli": "VITE_SUBSCRIPTIONS_ENABLED=false vite --mode eddeli --clearScreen false",
    "eddeli": "VITE_SUBSCRIPTIONS_ENABLED=true vite --mode eddeli --clearScreen false",
    "dev:store": "VITE_SUBSCRIPTIONS_ENABLED=false vite --mode store --clearScreen false",
    "store": "VITE_SUBSCRIPTIONS_ENABLED=true vite --mode store --clearScreen false",
    "raptor": "vite --mode raptor --clearScreen false",
    "build": "npm run build-eddeli",
    "build:app": "node scripts/build-app.mjs",
    "build-eddeli": "node scripts/build-app.mjs eddeli",
    "build-store": "node scripts/build-app.mjs store",
    "build-raptor": "node scripts/build-app.mjs raptor",
    "build:eddeli": "npm run build-eddeli",
    "build:store": "npm run build-store",
    "build:raptor": "npm run build-raptor",
    "generate:guest-data": "node scripts/generate-guest-data.mjs",
    "preview": "vite preview --mode eddeli",
    "preview:store": "vite preview --mode store",
    "preview:raptor": "vite preview --mode raptor"
  },
  "overrides": {
    "@mui/system": "5.18.0",
    "@mui/styled-engine": "5.18.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.18.0",
    "@mui/styled-engine": "5.18.0",
    "@mui/system": "5.18.0",
    "@mui/x-charts": "^7.29.1",
    "@mui/x-data-grid": "^7.21.0",
    "axios": "^1.6.8",
    "date-fns": "^4.1.0",
    "driver.js": "^1.7.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lightweight-charts": "^5.2.0",
    "notistack": "^3.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-easy-crop": "^5.5.1",
    "react-hook-form": "^7.51.2",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.22.2",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.11"
  }
