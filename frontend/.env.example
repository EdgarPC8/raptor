# Frontend compartido Raptor (AppsWeb/raptor/frontend)
#   npm run eddeli  → .env.eddeli  (API eddeliapi :3001)
#   npm run store   → .env.store   (API storeapi  :3003)
#
# Copiá/ajustá .env.eddeli y .env.store. Opcional: .env / .env.local

VITE_BASE_PATH=/eddeli/
VITE_API_PREFIX=eddeliapi
VITE_API_PORT=3001
VITE_API_HOST=127.0.0.1
VITE_API_ORIGIN=https://aplicaciones.marianosamaniego.edu.ec
VITE_API_MODE=local
VITE_MEDIA_PREFIX=sistema
VITE_DEV_PORT=5173
VITE_APP_NAME=EdDeli
VITE_APP_ID=eddeli
# VITE_SUBSCRIPTIONS_ENABLED=true
