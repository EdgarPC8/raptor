# Modo desarrollo EdDeli
#   npm run eddeli      → con permisos/entitlement (VITE_SUBSCRIPTIONS_ENABLED=true)
#   npm run dev:eddeli  → libre, sin permisos (fuerza VITE_SUBSCRIPTIONS_ENABLED=false)
VITE_BASE_PATH=/eddeli/
VITE_API_PREFIX=eddeliapi
VITE_API_PORT=3001
VITE_API_HOST=127.0.0.1
VITE_API_ORIGIN=https://aplicaciones.marianosamaniego.edu.ec
VITE_MEDIA_PREFIX=sistema
VITE_DEV_PORT=5173
VITE_APP_NAME=EdDeli
VITE_APP_ID=eddeli
VITE_SUBSCRIPTIONS_ENABLED=true
